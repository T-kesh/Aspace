{
  "cleanUrls": true,
  "outputDirectory": "frontend/dist",
  "rewrites": [
    {
      "source": "/dapp",
      "destination": "/dapp/index.html"
    },
    {
      "source": "/dapp/(.*)",
      "destination": "/dapp/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
